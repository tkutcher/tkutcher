
" === Core ===
syntax enable
filetype plugin indent on

" === Display ===
set cursorline
set showmatch
set scrolloff=8
set nowrap

" === Indentation ===
set tabstop=4
set shiftwidth=4
set expandtab
set autoindent
set smartindent

" === Behavior ===
set mouse=a
set laststatus=2
set ruler
set clipboard=unnamedplus
set backspace=indent,eol,start

